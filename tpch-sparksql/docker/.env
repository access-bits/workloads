# Docker image
IMAGE=akrishnaams/access-bits-tpch-sparksql:latest

# TPC-H scale factor (1 = ~1GB, 8 = ~8GB, 10 = ~10GB)
SF=8

# CPU pinning (e.g. 0-7 for 8 cores, or 0 for a single core)
CPUS=0-31

# Host paths for data and results volumes (relative to docker-compose file location)
DATA_DIR=/mnt/sdb/arun/workloads/tpch-sparksql
RESULTS_DIR=/tmp/results

# Spark tuning
SPARK_DRIVER_MEMORY=8g
SPARK_SHUFFLE_PARTITIONS=32

# Optional: run a single query (1-22). Leave empty to run all 22.
TPCH_QUERY=
