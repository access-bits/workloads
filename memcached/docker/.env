# Memcached configuration
MEMORY=64
PORT=11211
THREADS=4

# YCSB configuration file path (relative to docker folder or absolute path)
CONFIG_FILE=../src/ycsb-config.json

# CPU pinning configuration
# Memcached gets CPUs 0 to (THREADS-1)
# YCSB gets CPUs THREADS to (nproc-1)
# Example for THREADS=4 on a 16-core machine:
MEMCACHED_CPUS=0-3
YCSB_CPUS=4-15
